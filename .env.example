# ============================================================
# Telli Local Setup - Konfiguration
# ============================================================
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# ODER führe das Setup-Skript aus:
#   Windows:   .\setup.ps1
#   Linux/Mac: bash setup.sh
# ============================================================

# ------------------------------------------------------------
# LLM Provider (PFLICHT)
# ------------------------------------------------------------

# Dein API-Schlüssel beim LLM-Anbieter
# Beispiele:
#   IONOS AI Model Hub: https://cloud.ionos.de/ai
#   OpenAI:             https://platform.openai.com/api-keys
LLM_API_KEY=sk-dein-api-schluessel-hier

# Base URL des LLM-Providers (OpenAI-kompatibel)
# Für IONOS: https://openai.ionos.de/openai
# Für OpenAI: https://api.openai.com/v1
# Für andere OpenAI-kompatible APIs: entsprechende URL eintragen
LLM_BASE_URL=https://openai.ionos.de/openai

# ------------------------------------------------------------
# Sicherheitsschlüssel
# Werden von setup.ps1 / setup.sh automatisch generiert.
# Beim manuellen Setup: zufällige Strings generieren.
# ------------------------------------------------------------

# Zufälliger 64-Zeichen-String für NextAuth Session-Verschlüsselung
# Generieren: openssl rand -hex 32   (Linux/Mac)
# PowerShell: -join ((1..64)|%{[char](Get-Random -Min 97 -Max 123)})
AUTH_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING

# Zufälliger 32-Zeichen-String für Datenverschlüsselung
# Generieren: openssl rand -hex 16   (Linux/Mac)
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_32_CHAR_STRING

# ------------------------------------------------------------
# Datenbank (optional)
# Lass leer für den Standardwert 'telli-local-1234'
# ------------------------------------------------------------
DB_PASSWORD=
